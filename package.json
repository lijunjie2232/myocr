{
  "name": "myocr",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "apps/desktop/dist/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "cross-env NODE_ENV=production vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-rebuild",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && npm run electron:build-dev && cross-env NODE_ENV=development electron .\"",
    "electron:build-dev": "cd apps/desktop && node build.config.js",
    "electron:build": "npm run build:prod && npm run electron:build-dev && electron-builder",
    "electron:build:win": "npm run build:prod && npm run electron:build-dev && electron-builder --win",
    "electron:build:mac": "npm run build:prod && npm run electron:build-dev && electron-builder --mac",
    "electron:build:linux": "npm run build:prod && npm run electron:build-dev && electron-builder --linux",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@langchain/anthropic": "^1.3.24",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/groq": "^1.1.5",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@webcontainer/api": "^1.6.1",
    "better-sqlite3": "^12.8.0",
    "process": "^0.11.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@types/browserify": "^12.0.40",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "browserify": "^17.0.1",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "path-browserify": "^1.0.1",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "tsify": "^5.0.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "util": "^0.12.5",
    "vite": "^8.0.0-beta.13",
    "vite-plugin-remove-console": "^2.2.0",
    "wait-on": "^9.0.4"
  },
  "dependenciesMeta": {
    "better-sqlite3": {
      "built": true
    }
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
